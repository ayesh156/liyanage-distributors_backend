# ═══════════════════════════════════════════════════════════
# LIYANAGE DISTRIBUTORS - PRODUCTION ENVIRONMENT CONFIGURATION
# Contabo VPS Deployment Settings
# ═══════════════════════════════════════════════════════════

# Database Connection (Production MySQL Server)
DATABASE_URL="mysql://username:password@localhost:3306/liyanage_distributors_prod?connection_limit=50"

# Server Configuration
PORT=5000
NODE_ENV=production

# CORS Configuration
# Replace with your actual production frontend URL
FRONTEND_URL=https://your-frontend-domain.com
PRODUCTION_URL=https://your-frontend-domain.com

# Security
# Add your production security keys here
# JWT_SECRET=your-secret-key-here
# SESSION_SECRET=your-session-secret-here

# ═══════════════════════════════════════════════════════════
# DEPLOYMENT CHECKLIST FOR CONTABO VPS:
# ═══════════════════════════════════════════════════════════
# 1. Update DATABASE_URL with production credentials
# 2. Set FRONTEND_URL to your deployed frontend domain
# 3. Set NODE_ENV=production
# 4. Run: npx prisma migrate deploy
# 5. Run: npx prisma generate
# 6. Restart your backend service (PM2/systemd)
# 7. Test CORS by making requests from frontend
# ═══════════════════════════════════════════════════════════
